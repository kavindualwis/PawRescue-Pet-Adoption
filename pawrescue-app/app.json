{
  "expo": {
    "name": "pawrescue-app",
    "slug": "pawrescue-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/splash_image.png",
    "scheme": "pawrescueapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "config": {
        "googleMapsApiKey": "AIzaSyCZ1MzvV0ndr3tZZo1TyJ8q01HjjOtBCOU"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF5E6",
        "foregroundImage": "./assets/images/splash_image.png",
        "backgroundImage": "./assets/images/splash_image.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCZ1MzvV0ndr3tZZo1TyJ8q01HjjOtBCOU"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/splash_image.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
